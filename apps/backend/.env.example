APP_NAME="X3 CRM API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:4000

FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000
PORT=4000

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
