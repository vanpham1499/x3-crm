APP_NAME="X3 CRM API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:4000

FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000
PORT=4000

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=x3_crm_session
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_USE_URL=false
# Chỉ cần đổi biến này thành local hoặc server rồi chạy: php artisan config:clear
DB_PROFILE=local

# PostgreSQL trong Docker local (compose.local.yml)
DB_LOCAL_USE_URL=false
DB_LOCAL_HOST=127.0.0.1
DB_LOCAL_PORT=5433
DB_LOCAL_DATABASE=x3crm
DB_LOCAL_USERNAME=x3crm
DB_LOCAL_PASSWORD=x3crm123

# PostgreSQL trên VPS qua SSH tunnel (scripts/db-server-tunnel.cmd)
DB_SERVER_USE_URL=false
DB_SERVER_HOST=127.0.0.1
DB_SERVER_PORT=5434
DB_SERVER_DATABASE=x3crm
DB_SERVER_USERNAME=x3crm
DB_SERVER_PASSWORD=replace-with-server-database-password

# Cấu hình cũ vẫn được dùng khi DB_PROFILE=default hoặc biến profile bị thiếu.
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=x3crm
DB_USERNAME=x3crm
DB_PASSWORD=x3crm123

# Shared secret the bank/payment webhook must send back as
# `Authorization: Apikey <secret>` (SePay) or `Authorization: Bearer <secret>`.
# Required — the webhook rejects every request while this is empty.
PAYMENT_WEBHOOK_SECRET=
